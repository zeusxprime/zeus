BOT_TOKEN=COLE_SEU_TOKEN_AQUI
ADMIN_IDS=123456789
ADMIN_DISPLAY_NAME=Admin
WHATSAPP_ADMIN_NUMBERS=
SERVER_HOST=
SSH_PORTS=22,80,443
SSH_SHELL=/bin/false
BOT_DATA_DIR=/etc/primecel-gestor
GESTOR_DB_PATH=/etc/primecel-gestor/gestor.db
USUARIOS_DB_PATH=/root/usuarios.db
CHECKUSER_DB_PATH=/root/db.sqlite3
PRINCIPAL_MANAGER_ONLY=0
REMOTE_AGENT_PORT=8787
REMOTE_AGENT_TOKEN=
REMOTE_VPS_CONFIG=/etc/primecel-gestor/servers.conf
CHECKUSER_HOST=0.0.0.0
CHECKUSER_PORT=2052
CHECKUSER_PUBLIC_URL=https://check.primecel.shop
CHECKUSER_CENTRAL_MODE=1
VPN_DNS_DOMAIN=
VPN_DNS_ENABLED=0
VPN_DNS_INTERVAL=60
CLOUDFLARE_API_TOKEN=
VPS_SUSPENSION_INTERVAL=5
ONLINE_XRAY_WINDOW_SECONDS=30
XRAY_CREATE_ENABLED=1
WHATSAPP_AUTH_DIR=/etc/primecel-gestor/whatsapp-auth
ENABLE_DIRECT_XRAY_CONFIG=1
XRAY_CONFIG_PATHS=/usr/local/etc/xray/config.json,/etc/xray/config.json,/opt/xray/config.json
XRAY_INBOUND_TAG=inbound-dragoncore
XRAY_PROTOCOL=vless
DRAGONCORE_XRAY_PROTOCOL=xhttp
XRAY_FLOW=
XRAY_RESTART_COMMAND=systemctl restart xray || systemctl restart xray.service || systemctl restart v2ray || true
ENABLE_DRAGONCORE_PG=1
DRAGONCORE_DB=dragoncore
DRAGONCORE_PSQL_BIN=psql
DRAGONCORE_PSQL_USER=postgres
XRAY_LINK_PORT=443
XRAY_LINK_SECURITY=tls
XRAY_LINK_NETWORK=xhttp
XRAY_LINK_SNI=
XRAY_LINK_HOST=
XRAY_LINK_PATH=/
XRAY_LINK_EXTRA=
XRAY_ACCESS_LOG_PATHS=/var/log/xray/access.log,/usr/local/var/log/xray/access.log,/usr/local/etc/xray/access.log,/var/log/v2ray/access.log
